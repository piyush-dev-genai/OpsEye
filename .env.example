NODE_ENV=development
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=3000
LOG_LEVEL=debug

KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=opseye
KAFKA_GROUP_ID_PREFIX=opseye

VECTOR_STORE_URL=redis://redis:6379
VECTOR_STORE_INDEX=opseye

LLM_API_KEY=replace-with-provider-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_CHAT_MODEL=replace-with-your-chat-model-or-deployment
LLM_EMBEDDING_MODEL=replace-with-your-embedding-model-or-deployment

# Optional backward-compatible fallback when one model or deployment is used
# for both chat and embeddings.
# LLM_MODEL=replace-with-your-shared-model-or-deployment

# Set this only when your provider requires an API version, for example Azure OpenAI.
# LLM_API_VERSION=2024-02-01
